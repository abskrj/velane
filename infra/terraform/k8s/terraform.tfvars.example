# =============================================================================
# Velane — Kubernetes stack configuration example
#
# Copy this file to terraform.tfvars and fill in your values.
# Lines starting with # are comments / optional overrides.
# =============================================================================

# =============================================================================
# CLUSTER ACCESS
# =============================================================================

kubeconfig_path    = "~/.kube/config"
kubeconfig_context = "your-cluster-context"  # e.g. "velane-us-east-1"

namespace        = "velane"
create_namespace = true

# =============================================================================
# CONTAINER IMAGES
# =============================================================================

control_plane_image   = "ghcr.io/abskrj/velane-control-plane:latest"
bun_executor_image    = "ghcr.io/abskrj/velane-bun-executor:latest"
python_executor_image = "ghcr.io/abskrj/velane-python-executor:latest"
admin_image           = "ghcr.io/abskrj/velane-admin:latest"
mcp_server_image      = "ghcr.io/abskrj/velane-mcp-server:latest"

# =============================================================================
# CORE DEPENDENCIES  (bring your own — not provisioned by this stack)
# =============================================================================

# Postgres: Supabase, Neon, RDS, or any standard postgres DSN
database_url = "postgresql://postgres:PASSWORD@HOST:5432/postgres"

# Redis / Valkey: Aiven, Upstash, ElastiCache, etc.
redis_url = "rediss://default:PASSWORD@HOST:PORT"

# 64-char hex AES-256 key — generate with: openssl rand -hex 32
encryption_key = "REPLACE_WITH_64_HEX_CHARS"

# RS256 private key for session JWTs — generate with: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt
jwt_private_key_pem = <<EOT
-----BEGIN PRIVATE KEY-----
REPLACE_ME
-----END PRIVATE KEY-----
EOT

# =============================================================================
# BOOTSTRAP  (first deploy only — remove after first successful boot)
# =============================================================================

bootstrap_email    = "admin@example.com"
bootstrap_password = "change-me-immediately"
bootstrap_tenant   = "default"

# =============================================================================
# DOMAIN + TLS  (ALB Ingress with ACM — recommended for production)
# =============================================================================

enable_ingress     = true
ingress_class_name = "alb"   # "alb" on EKS | "nginx" | "gce" on GKE | "azure/application-gateway" on AKS

# Your root domain. Subdomains are created under this.
base_domain = "yourdomain.com"

# Subdomain layout (defaults work for most deployments):
admin_subdomain         = "admin"    # admin.yourdomain.com
api_subdomain           = "api"      # api.yourdomain.com
mcp_subdomain           = "mcp"      # mcp.yourdomain.com
mcp_public_url          = ""         # optional override; defaults to https://mcp.yourdomain.com/mcp when ingress is enabled
nango_connect_subdomain = "connect"  # connect.yourdomain.com
nango_api_subdomain     = "nango"    # nango.yourdomain.com

# ACM certificate ARN (HTTPS on port 443 — free, strongly recommended).
# Get from: terraform -chdir=infra/terraform/aws-eks output -raw acm_certificate_arn
# Leave empty for HTTP-only (not recommended for production).
acm_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERTIFICATE_ID"

# Extra ingress annotations. The ALB scheme and target-type are added automatically.
# You can override or add more here.
ingress_annotations = {}

# =============================================================================
# SERVICE TYPES  (only matter when enable_ingress = false)
# When enable_ingress = true, services switch to ClusterIP automatically.
# =============================================================================

admin_service_type         = "LoadBalancer"
control_plane_service_type = "LoadBalancer"
mcp_server_service_type    = "LoadBalancer"

# =============================================================================
# NANGO  (in-cluster OAuth + API proxy)
# =============================================================================

deploy_nango = true
nango_image  = "nangohq/nango-server:hosted"

# Nango database:
# - Leave empty → a separate "nango" database is auto-created on your main Postgres server
# - Set to a full DSN to use a completely separate Postgres instance
# nango_database_url = "postgresql://user:pass@HOST:5432/nango"

# Nango auth keys — generate two separate UUIDs:
#   python -c "import uuid; print(uuid.uuid4())"
nango_secret_key     = "REPLACE_WITH_UUID"
nango_public_key     = "REPLACE_WITH_DIFFERENT_UUID"
nango_webhook_secret = ""

# Nango encryption key (32-byte base64):
#   openssl rand -base64 32
# nango_encryption_key = "REPLACE_WITH_BASE64_KEY"

# Internal URL stays as-is when Nango is deployed in-cluster.
nango_internal_url = "http://nango:3003"

# Public Nango URLs are auto-derived from nango_*_subdomain + base_domain.
# Override only if you need a non-standard URL.
nango_connect_url = ""
nango_api_url     = ""

# =============================================================================
# OBSERVABILITY  (optional)
# =============================================================================

# clickhouse_dsn = "clickhouse://user:pass@HOST:9000/velane"
# logs_bucket    = "my-velane-logs"
# replay_bucket  = "my-velane-replays"
