# Copy to backend.hcl and adjust for your AWS account, then run:
#   tofu init -backend-config=backend.hcl -migrate-state
#
# Create the bucket and lock table once (replace names/region as needed):
#   aws s3api create-bucket --bucket velane-terraform-state-ACCOUNT_ID --region us-east-1
#   aws dynamodb create-table \
#     --table-name velane-terraform-locks \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST \
#     --region us-east-1

bucket         = "velane-terraform-state-ACCOUNT_ID"
key            = "k8s/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "velane-terraform-locks"
encrypt        = true
